# Firebase Web アプリ設定（Firebase Console → プロジェクトの全般 → マイアプリ）
# App Hosting ではコンソール / apphosting.yaml / .env のいずれかで同等の値を設定します。
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google Analytics 4（gtag / 任意）
# GA4 のデータストリームで取得した測定ID（例: G-XXXXXXXXXX）
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Firestore 利用時: Firebase Console → 認証 → ログイン方法 → メール/パスワード を有効化してください（匿名ログインは使用しません）。

# 広告表示設定（任意）
# 0: 広告機能を完全オフ / 1 or 未設定: オン
# NEXT_PUBLIC_ADS_ENABLED=1
# 1: 常に広告非表示（開発者確認用）
# NEXT_PUBLIC_ADS_FORCE_HIDE=0
# 1: iOSホーム画面アプリ(PWA)では広告を非表示
# 0 or 未設定: iOS PWAでも広告表示を試みる（デフォルト）
# NEXT_PUBLIC_ADS_DISABLE_IOS_PWA=0
# AdSense 接続（必須: client/slot 両方）
# 例: ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=
# 例: 1234567890（メモ編集画面下部の広告ユニット）
# NEXT_PUBLIC_ADSENSE_SLOT_EDITOR=
# 固定サイズを選択（未設定時は 320x100）
# 許可値: 320x100 / 300x250
# NEXT_PUBLIC_ADSENSE_EDITOR_SIZE=320x100

# 買い切りMVP（暫定ローカル検証）
# 現在は静的配信のため API 検証を使わず、入力キー一致で広告非表示にします。
# NEXT_PUBLIC_PURCHASE_DEMO_LICENSE=

# 管理者PIN（平文PINの SHA-256 を16進で64文字。先頭の 0x は付けない）
# 例: PIN "1234" の SHA-256 => 03ac674216f3e15c761ee1a5e255f067953623c8b388b4459e13f978d7c846f4
# ローカル: 設定後は npm run dev を再起動。本番: GitHub Repository secrets に
# NEXT_PUBLIC_ADMIN_PIN_SHA256 を追加し、ワークフローの build env で渡す。
# NEXT_PUBLIC_ADMIN_PIN_SHA256=
