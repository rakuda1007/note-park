# Firebase Web アプリ設定（Firebase Console → プロジェクトの全般 → マイアプリ）
# App Hosting ではコンソール / apphosting.yaml / .env のいずれかで同等の値を設定します。
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Analytics を使う場合（任意）
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firestore 利用時: Firebase Console → 認証 → ログイン方法 → メール/パスワード を有効化してください（匿名ログインは使用しません）。

# 広告表示設定（任意）
# 0: 広告機能を完全オフ / 1 or 未設定: オン
# NEXT_PUBLIC_ADS_ENABLED=1
# 1: 常に広告非表示（開発者確認用）
# NEXT_PUBLIC_ADS_FORCE_HIDE=0
# AdSense 接続（必須: client/slot 両方）
# 例: ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=
# 例: 1234567890（メモ編集画面下部の広告ユニット）
# NEXT_PUBLIC_ADSENSE_SLOT_EDITOR=
